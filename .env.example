# ===== Required in all environments =====

# Server
NODE_ENV=development
PORT=3200
HOST=0.0.0.0

# Database (use Neon connection string in production)
DATABASE_URL=postgresql://blossom:your_password@localhost:5434/blossom

# Redis (use Upstash connection string in production)
REDIS_URL=redis://localhost:6381

# Secrets — generate with:
#   JWT_SECRET:     openssl rand -hex 64
#   ENCRYPTION_KEY: openssl rand -base64 32
# ENCRYPTION_KEY is CRITICAL: if lost in production, all encrypted data
# (e.g. channel credentials) becomes unrecoverable.
JWT_SECRET=change_me_to_a_64_char_random_hex_string_for_production_use
ENCRYPTION_KEY=change_me_to_a_32_byte_base64_random_string

# Comma-separated list of origins allowed to call the API
CORS_ORIGINS=http://localhost:3000,http://localhost:3201

# Modules enabled for this deployment
ENABLED_MODULES=logistica-acme

# ===== Required in production =====

# Public base URL of this API — used to build webhook callback URLs (Twilio, etc).
# In dev, use the ngrok subdomain. In prod, the real domain (e.g. https://api.axisapp.com.br).
# PUBLIC_API_URL=https://api.your-domain.com

# Google Cloud Storage — required when uploads should not hit the local filesystem.
# GCS_BUCKET_NAME=axis-files
# GOOGLE_APPLICATION_CREDENTIALS_JSON={"type":"service_account",...}

# ===== Optional =====

# AI providers (only required if AI bots are configured)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# SMTP (only required if email channel is used)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=noreply@example.com

# Logging
# LOG_LEVEL=info
