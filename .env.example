# ===== Required in all environments =====

# Server
NODE_ENV=development
PORT=3200
HOST=0.0.0.0

# Database (use Neon connection string in production)
DATABASE_URL=postgresql://blossom:your_password@localhost:5434/blossom

# Redis (use Upstash connection string in production)
REDIS_URL=redis://localhost:6381

# Secrets — generate with:
#   JWT_SECRET:     openssl rand -hex 64
#   ENCRYPTION_KEY: openssl rand -base64 32
# ENCRYPTION_KEY is CRITICAL: if lost in production, all encrypted data
# (e.g. channel credentials) becomes unrecoverable.
JWT_SECRET=change_me_to_a_64_char_random_hex_string_for_production_use
ENCRYPTION_KEY=change_me_to_a_32_byte_base64_random_string

# Comma-separated list of origins allowed to call the API
CORS_ORIGINS=http://localhost:3000,http://localhost:3201

# Modules enabled for this deployment
ENABLED_MODULES=logistica-acme

# ---- Atlas integration (Phase 0 — account linking + SSO) ----
# Shared secret. Atlas sends it as `X-API-Key` to call /api/auth/check-email,
# /api/auth/verify-credentials, and /api/auth/create-from-atlas.
# Same value as AXIS_API_KEY in Atlas. Generate with: openssl rand -hex 32
ATLAS_API_KEY=

# HS256 secret used to verify the short-lived `atlas_token` JWTs Atlas signs
# for the messaging iframe (POST /api/auth/exchange-iframe-token). Same value
# as AXIS_JWT_SECRET in Atlas. Generate with: openssl rand -hex 64
AXIS_JWT_SECRET=

# ---- Atlas integration (Phase A — playbook fetch) ----
# URL do Atlas pra fetch playbook; vazio desativa fetch (bot cai pro inline
# systemPrompt). Em dev local: http://localhost:3010. Em Docker network: http://atlas-web:3010.
ATLAS_BASE_URL=

# ---- Atlas integration (Phase B — outbound events) ----
# Shared secret pra HMAC sign de eventos pra Atlas; vazio desativa enqueuer.
# Mesmo valor que ATLAS_EVENTS_HMAC_SECRET em Atlas. Generate: openssl rand -hex 32
ATLAS_EVENTS_HMAC_SECRET=

# ---- Atlas integration (Phase D — Phase 12 connector + MCP server) ----
# Phase D promotes axis-back to a full Atlas Phase 12 connector: events flow into
# `shadow_records` via /api/connectors/messaging/events and Atlas can call MCP
# tools (messaging.get_thread, send_message, etc.) hosted in this process.
#
# Master switch for the MCP server route. Default false (Phase D.2/D.3 dormant).
# Flip to true in Render env once Atlas Phase 11+12 are merged and the
# `mcp_servers` row is provisioned.
MCP_SERVER_ENABLED=false

# Shared HMAC secret Atlas signs MCP requests with (header: X-Atlas-Signature).
# Kept separate from ATLAS_EVENTS_HMAC_SECRET for separation of concerns:
# rotating one channel must not invalidate the other. Required only when
# MCP_SERVER_ENABLED=true AND MCP_AUTH_MODE='hmac' (boot fails). When
# MCP_AUTH_MODE='both' and this is unset, boot logs a warning and continues
# (Bearer-only at runtime, HMAC fallback unavailable). Generate: openssl rand -hex 32
ATLAS_MCP_HMAC_SECRET=

# Static API key for Atlas Phase 11 MCP auth — gen via `openssl rand -hex 32`.
# Same value goes into Atlas worker Render env (referenced by mcp_servers.headers
# JSON as `{"Authorization":{"ref":"env://MCP_AXIS_API_KEY"}}`). Required when
# MCP_SERVER_ENABLED=true AND MCP_AUTH_MODE in ['bearer','both'].
MCP_AXIS_API_KEY=

# MCP auth mode: `hmac` | `bearer` | `both`. Default `both` accepts either
# scheme (Bearer primary, HMAC fallback). `both` during migration period;
# `bearer` once HMAC code path can be removed; `hmac` as rollback escape hatch
# (note: requires Atlas-side flip too — see LESSONS L-505).
MCP_AUTH_MODE=both

# Phase 12 envelope feature flag. Default `false` emits Phase B literal shape
# (`type:'message_sent'` etc.) into the Atlas-events queue. Flip `true` ONLY
# when Phase 12 connector receiver is live Atlas-side (endpoint
# /api/connectors/messaging/events ativo). Worker dual-shape narrowing handles
# both shapes during the drain window.
USE_PHASE_12_ENVELOPE=false

# Atlas-side endpoint that axis-back POSTs envelopes to. Default
# `/api/messaging/events` (Phase B endpoint in prod). Flip to
# `/api/connectors/messaging/events` when Phase 12 entra. Coordinated with
# USE_PHASE_12_ENVELOPE flag.
ATLAS_EVENTS_ENDPOINT=/api/messaging/events

# ===== Required in production =====

# Public base URL of this API — used to build webhook callback URLs (Twilio, etc).
# In dev, use the ngrok subdomain. In prod, the real domain (e.g. https://api.axisapp.com.br).
# PUBLIC_API_URL=https://api.your-domain.com

# Google Cloud Storage — required when uploads should not hit the local filesystem.
# GCS_BUCKET_NAME=axis-files
# Optional: prefix to scope writes inside a shared bucket (e.g. when using
# the same bucket as another app). Final path = {prefix}/uploads/{accountId}/{uuid}.{ext}.
# GCS_PATH_PREFIX=axis
# GOOGLE_APPLICATION_CREDENTIALS_JSON={"type":"service_account",...}

# ===== Optional =====

# AI providers (only required if AI bots are configured)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# SMTP (only required if email channel is used)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=noreply@example.com

# Google OAuth (only required if Gmail email channel is used).
# OAuth routes return 503 if any of these is missing when a Gmail flow is invoked.
# Obtain credentials from the GCP console (APIs & Services → Credentials → OAuth 2.0 Client IDs).
# The redirect URI must match exactly what is registered in GCP.
# GOOGLE_OAUTH_CLIENT_ID=1234.apps.googleusercontent.com
# GOOGLE_OAUTH_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxx
# GOOGLE_OAUTH_REDIRECT_URI=https://axis-back.onrender.com/api/v1/oauth/google/callback

# Public base URL of the frontend (used by /oauth/google/callback to redirect
# back into the app). Required when the Gmail OAuth flow is enabled.
# FRONT_URL=https://app.your-domain.com

# Logging
# LOG_LEVEL=info
