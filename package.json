{
  "name": "axis-back",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "tsx src/server.ts",
    "seed:admin": "tsx src/scripts/seed-admin.ts",
    "type-check": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest run",
    "db:generate": "pnpm --filter @blossom/db run generate",
    "db:migrate": "pnpm --filter @blossom/db run migrate",
    "db:studio": "pnpm --filter @blossom/db run studio",
    "docker:up": "docker compose -f infra/docker-compose.dev.yml up -d",
    "docker:down": "docker compose -f infra/docker-compose.dev.yml down"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@aws-sdk/client-s3": "^3.1038.0",
    "@blossom-modules/catalog": "workspace:*",
    "@blossom/db": "workspace:*",
    "@blossom/sdk": "workspace:*",
    "@blossom/shared-types": "workspace:*",
    "@fastify/cors": "^10.0.1",
    "@fastify/helmet": "^13.0.0",
    "@fastify/jwt": "^9.0.3",
    "@fastify/multipart": "^9.4.0",
    "@fastify/rate-limit": "^10.2.1",
    "@fastify/sensible": "^6.0.1",
    "@fastify/static": "^9.1.1",
    "@fastify/swagger": "^9.4.0",
    "@fastify/swagger-ui": "^5.2.0",
    "@fastify/websocket": "^11.0.1",
    "@node-rs/argon2": "^2.0.2",
    "bullmq": "^5.34.0",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.38.3",
    "fastify": "^5.2.0",
    "fastify-plugin": "^5.0.1",
    "ioredis": "^5.4.1",
    "nodemailer": "^8.0.5",
    "openai": "^6.34.0",
    "pino-pretty": "^13.0.0",
    "postgres": "^3.4.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/nodemailer": "^8.0.0",
    "@types/ws": "^8.5.13",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
